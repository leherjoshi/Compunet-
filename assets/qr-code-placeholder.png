<svg width="200" height="200" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="200" height="200" fill="#f9fafb"/>
  
  <!-- Border -->
  <rect x="10" y="10" width="180" height="180" fill="none" stroke="#e5e7eb" stroke-width="2"/>
  
  <!-- QR Code Pattern Simulation -->
  <g fill="#1f2937">
    <!-- Top-left corner -->
    <rect x="20" y="20" width="50" height="50" rx="2"/>
    <rect x="30" y="30" width="30" height="30" fill="#f9fafb"/>
    <rect x="40" y="40" width="10" height="10"/>
    
    <!-- Top-right corner -->
    <rect x="130" y="20" width="50" height="50" rx="2"/>
    <rect x="140" y="30" width="30" height="30" fill="#f9fafb"/>
    <rect x="150" y="40" width="10" height="10"/>
    
    <!-- Bottom-left corner -->
    <rect x="20" y="130" width="50" height="50" rx="2"/>
    <rect x="30" y="140" width="30" height="30" fill="#f9fafb"/>
    <rect x="40" y="150" width="10" height="10"/>
    
    <!-- Center pattern -->
    <rect x="80" y="80" width="10" height="10"/>
    <rect x="95" y="80" width="10" height="10"/>
    <rect x="110" y="80" width="10" height="10"/>
    <rect x="80" y="95" width="10" height="10"/>
    <rect x="110" y="95" width="10" height="10"/>
    <rect x="80" y="110" width="10" height="10"/>
    <rect x="95" y="110" width="10" height="10"/>
    <rect x="110" y="110" width="10" height="10"/>
    
    <!-- Random pattern blocks -->
    <rect x="80" y="30" width="8" height="8"/>
    <rect x="95" y="30" width="8" height="8"/>
    <rect x="110" y="40" width="8" height="8"/>
    <rect x="80" y="50" width="8" height="8"/>
    <rect x="100" y="55" width="8" height="8"/>
    
    <rect x="30" y="80" width="8" height="8"/>
    <rect x="45" y="85" width="8" height="8"/>
    <rect x="30" y="100" width="8" height="8"/>
    <rect x="50" y="105" width="8" height="8"/>
    
    <rect x="130" y="80" width="8" height="8"/>
    <rect x="145" y="90" width="8" height="8"/>
    <rect x="160" y="95" width="8" height="8"/>
    <rect x="140" y="110" width="8" height="8"/>
    
    <rect x="80" y="130" width="8" height="8"/>
    <rect x="95" y="135" width="8" height="8"/>
    <rect x="110" y="140" width="8" height="8"/>
    <rect x="100" y="155" width="8" height="8"/>
  </g>
  
  <!-- Text label -->
  <text x="100" y="195" font-family="Arial, sans-serif" font-size="10" fill="#6b7280" text-anchor="middle">QR Code Placeholder</text>
</svg>
